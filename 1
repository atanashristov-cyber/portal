        async function handleCreateUser(event) {
            event.preventDefault();
            const username = document.getElementById('new-username').value.trim().toLowerCase();
            const password = document.getElementById('new-password').value;
            const displayName = document.getElementById('new-display-name').value.trim() || username;
            const role = document.getElementById('new-role').value;
            let permissions = getSelectedPermissions('new-perm');
            if (role === 'admin') permissions = [...ALL_PERMISSIONS];
            if (!permissions.includes('view_portal')) permissions.unshift('view_portal');
            const errEl = document.getElementById('create-user-error');
            errEl.classList.add('hidden');
            try {
                if (usingLocalAuth) {
                    const users = getLocalUsers();
                    if (users[username]) throw new Error('Потребителят вече съществува.');
                    users[username] = { username, password, display_name: displayName, role, permissions, is_active: true, id: username };
                    saveLocalUsers(users);
                    document.getElementById('create-user-form').reset();
                    loadUsersTable();
                    return false;
                }
                const { data, error } = await signupClient.auth.signUp({
                    email: authEmail(username),
                    password,
                    options: { data: { username, display_name: displayName } }
                });
                if (error) throw error;
                if (!data.user) throw new Error('Потребителят не беше създаден.');
                const { error: profileError } = await supabaseClient.from('portal_profiles').upsert({
                    id: data.user.id,
                    username,
                    display_name: displayName,
                    role,
                    permissions,
                    is_active: true,
                    updated_at: new Date().toISOString()
                });
                if (profileError) throw profileError;
                document.getElementById('create-user-form').reset();
                loadUsersTable();
            } catch (err) {
                errEl.textContent = err.message || 'Грешка при създаване.';
                errEl.classList.remove('hidden');
            }
            return false;
        }

        async function loadUsersTable() {
            const tbody = document.getElementById('users-table-body');
            tbody.innerHTML = '';
            let rows = [];
            if (usingLocalAuth) {
                rows = Object.values(getLocalUsers());
            } else {
                const { data, error } = await supabaseClient.from('portal_profiles').select('*').order('username');
                if (error) throw error;
                rows = data || [];
            }
            rows.forEach((user) => {
                const tr = document.createElement('tr');
                tr.className = 'border-b border-gray-100';
                const perms = (user.permissions || []).join(', ');
                tr.innerHTML = `
                    <td class="py-3 pr-3 font-semibold">${user.display_name || user.username}<br><span class="text-xs text-gray-400">${user.username}</span></td>
                    <td class="py-3 pr-3">${user.role}</td>
                    <td class="py-3 pr-3 text-xs text-gray-500 max-w-[200px]">${perms}</td>
                    <td class="py-3 pr-3">${user.is_active ? 'Да' : 'Не'}</td>
                    <td class="py-3">
                        <button type="button" class="text-brand-orange font-bold text-xs mr-2" onclick="toggleUserActive('${user.username}', ${user.is_active ? 'false' : 'true'})">${user.is_active ? 'Спри' : 'Активирай'}</button>
