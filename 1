        function renderContentEditor() {
            const sectionKey = document.getElementById('content-section-select').value;
            const lang = document.getElementById('content-lang-select').value;
            const section = CONTENT_SECTIONS[sectionKey];
            const container = document.getElementById('content-editor-fields');
            container.innerHTML = '';
            if (!section || !section.keys || !section.keys.length) {
                container.innerHTML = '<p class="text-sm text-gray-500">За раздел „4. Доходи и Бонусна схема“ използвайте отделния бутон за пълен редактор.</p>';
                return;
            }
            (section.keys || []).forEach((key) => {
                const value = (translations[lang] && translations[lang][key]) || '';
                const wrap = document.createElement('div');
                wrap.innerHTML = `
                    <label class="admin-field-label">${key}</label>
                    <textarea data-content-key="${key}" rows="3" class="mt-1 w-full rounded-xl border border-gray-200 px-3 py-2 text-sm font-medium">${value.replace(/</g, '&lt;')}</textarea>`;
                const textarea = wrap.querySelector('textarea');
                textarea.value = value;
                textarea.addEventListener('input', (e) => {
                    if (!translations[lang]) translations[lang] = {};
                    translations[lang][key] = e.target.value;
                });
                container.appendChild(wrap);
            });
        }

