            });
        }

        async function toggleUserActive(username, active) {
            if (usingLocalAuth) {
                const users = getLocalUsers();
                if (!users[username]) return;
                users[username].is_active = active;
                saveLocalUsers(users);
                loadUsersTable();
                return;
            }
            const { error } = await supabaseClient.from('portal_profiles').update({ is_active: active, updated_at: new Date().toISOString() }).eq('username', username);
