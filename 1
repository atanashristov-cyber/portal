<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Takeaway - Единен Информационен Портал</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link class="scroll-smooth" rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <!-- Добавяне на Supabase SDK за безплатна облачна база данни -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            orange: '#FF7A00',
                            orangeLight: '#FFA142',
                            dark: '#111827',
                            grayDark: '#1F2937',
                            slate: '#4B5563',
                            lightBg: '#F9FAFB'
                        }
                    },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f8fafc; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #FF7A00; border-radius: 10px; }
        .leaflet-container { font-family: 'Inter', sans-serif; z-index: 1 !important; }
        .tooltip-content { display: none; opacity: 0; transition: opacity 0.3s; }
        .tooltip-container:hover .tooltip-content, .tooltip-container:focus-within .tooltip-content { display: block; opacity: 1; }
        .search-input:focus { box-shadow: 0 0 0 4px rgba(255, 122, 0, 0.25); }
        .result-card { animation: slideDown 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-12px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes pulse-orange { 0% { box-shadow: 0 0 0 0 rgba(255, 122, 0, 0.8); } 70% { box-shadow: 0 0 0 12px rgba(255, 122, 0, 0); } 100% { box-shadow: 0 0 0 0 rgba(255, 122, 0, 0); } }
        .pulse-marker { box-shadow: 0 0 0 0 rgba(255, 122, 0, 0.8); animation: pulse-orange 2s infinite; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
        .animate-blink { animation: blink 1.5s ease-in-out infinite; }
        .tab-section, .global-page { animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
        .glass-header { background: rgba(255, 255, 255, 0.75); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.6); }
        .interactive-card { transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
        .interactive-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.08); border-color: rgba(255, 122, 0, 0.3); }
        .app-screen { min-height: 100vh; }
        .admin-field-label { font-size: 11px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em; }
    </style>
</head>
<body class="bg-[#F3F4F6] text-gray-800 font-sans antialiased min-h-screen relative selection:bg-brand-orange selection:text-white">

    <div id="screen-login" class="app-screen flex items-center justify-center px-4 py-10">
        <div class="w-full max-w-md bg-white rounded-[2rem] border border-gray-200 shadow-lg p-8 space-y-6">
            <div class="text-center space-y-2">
                <span class="inline-block bg-brand-orange text-white text-xs font-black px-3 py-1 rounded-md">TAKEAWAY BG</span>
                <h1 class="text-2xl font-black text-brand-dark">Вход в портала</h1>
                <p class="text-sm text-gray-500">Потребителско име и парола</p>
            </div>
            <form id="login-form" class="space-y-4" onsubmit="return handleLoginSubmit(event)">
                <div>
                    <label class="admin-field-label" for="login-username">Потребител</label>
                    <input id="login-username" type="text" required autocomplete="username" class="mt-1 w-full rounded-xl border border-gray-200 px-4 py-3 font-semibold focus:outline-none focus:ring-2 focus:ring-brand-orange/40">
                </div>
                <div>
                    <label class="admin-field-label" for="login-password">Парола</label>
                    <input id="login-password" type="password" required autocomplete="current-password" class="mt-1 w-full rounded-xl border border-gray-200 px-4 py-3 font-semibold focus:outline-none focus:ring-2 focus:ring-brand-orange/40">
                </div>
                <p id="login-error" class="hidden text-sm text-red-600 font-semibold"></p>
                <button type="submit" class="w-full bg-brand-orange hover:bg-brand-orangeLight text-white font-bold py-3 rounded-xl shadow-sm transition">Вход</button>
            </form>
            <p id="login-config-hint" class="text-xs text-center text-gray-400"></p>
        </div>
    </div>

    <div id="screen-admin-choice" class="app-screen hidden flex items-center justify-center px-4 py-10">
        <div class="w-full max-w-2xl space-y-6">
            <div class="text-center space-y-2">
                <h1 class="text-3xl font-black text-brand-dark">Здравей, <span id="admin-choice-name">Админ</span></h1>
                <p class="text-gray-500">Избери режим на работа</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <button type="button" onclick="enterPortalView()" class="interactive-card bg-white border border-gray-200 rounded-[2rem] p-8 text-left space-y-3">
                    <div class="w-12 h-12 rounded-2xl bg-brand-orange/10 text-brand-orange flex items-center justify-center text-xl"><i class="fa-solid fa-motorcycle"></i></div>
                    <h2 class="text-xl font-black text-brand-dark">Потребителски портал</h2>
                    <p class="text-sm text-gray-500">Наръчникът за куриери – както го виждат служителите.</p>
                </button>
                <button type="button" onclick="enterAdminPanel()" class="interactive-card bg-white border border-gray-200 rounded-[2rem] p-8 text-left space-y-3">
                    <div class="w-12 h-12 rounded-2xl bg-gray-900 text-white flex items-center justify-center text-xl"><i class="fa-solid fa-screwdriver-wrench"></i></div>
                    <h2 class="text-xl font-black text-brand-dark">Администрация</h2>
                    <p class="text-sm text-gray-500">Потребители, права и редакция на съдържанието.</p>
                </button>
            </div>
            <div class="text-center">
                <button type="button" onclick="handleLogout()" class="text-sm font-bold text-gray-500 hover:text-brand-orange">Изход</button>
            </div>
        </div>
    </div>

    <div id="screen-admin" class="app-screen hidden">
        <header class="bg-white border-b border-gray-200 sticky top-0 z-[200]">
            <div class="max-w-6xl mx-auto px-4 py-4 flex flex-wrap items-center justify-between gap-3">
                <div>
                    <h1 class="text-xl font-black text-brand-dark">Администрация</h1>
                    <p class="text-xs text-gray-500" id="admin-user-label"></p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button type="button" onclick="showAdminSection('users')" id="admin-tab-users" class="px-4 py-2 rounded-xl text-sm font-bold bg-brand-orange text-white">Потребители</button>
                    <button type="button" onclick="showAdminSection('content')" id="admin-tab-content" class="px-4 py-2 rounded-xl text-sm font-bold bg-gray-100 text-gray-600">Съдържание</button>
                    <button type="button" onclick="openAdminChoice()" class="px-4 py-2 rounded-xl text-sm font-bold bg-gray-100 text-gray-600">Назад</button>
                    <button type="button" onclick="handleLogout()" class="px-4 py-2 rounded-xl text-sm font-bold bg-gray-100 text-gray-600">Изход</button>
                </div>
            </div>
        </header>
        <main class="max-w-6xl mx-auto px-4 py-8 space-y-8">
            <section id="admin-section-users" class="space-y-6">
                <div class="bg-white rounded-[2rem] border border-gray-200 p-6 space-y-4">
                    <h2 class="text-lg font-black text-brand-dark">Нов потребител</h2>
                    <form id="create-user-form" class="grid grid-cols-1 md:grid-cols-2 gap-4" onsubmit="return handleCreateUser(event)">
                        <div>
                            <label class="admin-field-label" for="new-username">Потребител</label>
                            <input id="new-username" required class="mt-1 w-full rounded-xl border border-gray-200 px-3 py-2.5 font-semibold">
                        </div>
                        <div>
                            <label class="admin-field-label" for="new-password">Парола</label>
                            <input id="new-password" type="password" required minlength="6" class="mt-1 w-full rounded-xl border border-gray-200 px-3 py-2.5 font-semibold">
                        </div>
                        <div>
                            <label class="admin-field-label" for="new-display-name">Име за показване</label>
                            <input id="new-display-name" class="mt-1 w-full rounded-xl border border-gray-200 px-3 py-2.5 font-semibold">
                        </div>
                        <div>
                            <label class="admin-field-label" for="new-role">Роля</label>
                            <select id="new-role" class="mt-1 w-full rounded-xl border border-gray-200 px-3 py-2.5 font-semibold">
                                <option value="user">Потребител</option>
                                <option value="admin">Администратор</option>
                            </select>
                        </div>
                        <div class="md:col-span-2">
                            <p class="admin-field-label mb-2">Права</p>
                            <div class="flex flex-wrap gap-4 text-sm font-semibold">
                                <label class="flex items-center gap-2"><input type="checkbox" name="new-perm" value="view_portal" checked> Достъп до портала</label>
                                <label class="flex items-center gap-2"><input type="checkbox" name="new-perm" value="view_company_cars" checked> Служебни коли</label>
                                <label class="flex items-center gap-2"><input type="checkbox" name="new-perm" value="manage_users"> Управление потребители</label>
                                <label class="flex items-center gap-2"><input type="checkbox" name="new-perm" value="manage_content"> Редакция съдържание</label>
                            </div>
                        </div>
                        <div class="md:col-span-2">
                            <p id="create-user-error" class="hidden text-sm text-red-600 font-semibold mb-2"></p>
                            <button type="submit" class="bg-brand-orange text-white font-bold px-5 py-2.5 rounded-xl">Създай потребител</button>
                        </div>
                    </form>
                </div>
                <div class="bg-white rounded-[2rem] border border-gray-200 p-6 overflow-x-auto">
                    <h2 class="text-lg font-black text-brand-dark mb-4">Списък потребители</h2>
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-gray-500 border-b">
                                <th class="py-2 pr-3">Потребител</th>
                                <th class="py-2 pr-3">Роля</th>
                                <th class="py-2 pr-3">Права</th>
                                <th class="py-2 pr-3">Активен</th>
                                <th class="py-2">Действия</th>
                            </tr>
                        </thead>
                        <tbody id="users-table-body"></tbody>
                    </table>
                </div>
            </section>
            <section id="admin-section-content" class="hidden space-y-6">
                <div class="bg-white rounded-[2rem] border border-gray-200 p-6 space-y-4">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <h2 class="text-lg font-black text-brand-dark">Редакция на потребителската страница</h2>
                        <button type="button" onclick="openMatrixEditor()" class="bg-gray-900 text-white font-bold px-5 py-2.5 rounded-xl hover:bg-gray-800 transition">
                            <i class="fa-solid fa-pen-to-square mr-2"></i>Редактирай „4. Доходи и Бонусна схема“
                        </button>
                    </div>
                    <p class="text-sm text-gray-500">Пълен редактор на раздел 4: текстове, таблици с бонуси, средни нетни суми и настройки на симулатора.</p>
                </div>
                <div class="bg-white rounded-[2rem] border border-gray-200 p-6 space-y-4">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <h2 class="text-lg font-black text-brand-dark">Други текстове на портала</h2>
                        <button type="button" onclick="savePortalContent()" class="bg-brand-orange text-white font-bold px-5 py-2.5 rounded-xl">Запази промените</button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <select id="content-section-select" onchange="renderContentEditor()" class="rounded-xl border border-gray-200 px-3 py-2 font-semibold"></select>
                        <select id="content-lang-select" onchange="renderContentEditor()" class="rounded-xl border border-gray-200 px-3 py-2 font-semibold">
                            <option value="bg">Български</option>
                            <option value="en">English</option>
                        </select>
                    </div>
                    <div id="content-editor-fields" class="grid grid-cols-1 gap-4"></div>
                    <p id="content-save-status" class="text-sm font-semibold text-green-600 hidden"></p>
                </div>
            </section>
        </main>
    </div>

    <div id="screen-admin-matrix" class="app-screen hidden">
        <header class="bg-white border-b border-gray-200 sticky top-0 z-[200]">
            <div class="max-w-5xl mx-auto px-4 py-4 flex flex-wrap items-center justify-between gap-3">
                <div>
                    <h1 class="text-xl font-black text-brand-dark">4. Доходи и Бонусна схема</h1>
                    <p class="text-xs text-gray-500">Пълен редактор на раздела</p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button type="button" onclick="saveMatrixFromAdmin()" class="px-4 py-2 rounded-xl text-sm font-bold bg-brand-orange text-white">Запази</button>
                    <button type="button" onclick="closeMatrixEditor()" class="px-4 py-2 rounded-xl text-sm font-bold bg-gray-100 text-gray-600">Назад</button>
                </div>
            </div>
        </header>
        <main class="max-w-5xl mx-auto px-4 py-8">
            <p id="matrix-save-status" class="hidden mb-4 text-sm font-semibold text-green-600"></p>
            <div id="matrix-admin-form" class="space-y-6"></div>
        </main>
    </div>

    <div id="screen-portal" class="hidden">
    <header id="main-header" class="sticky top-4 z-[100] mx-auto px-4 max-w-2xl transition-all duration-500 ease-in-out transform origin-top">
        <div class="bg-white/60 backdrop-blur-md rounded-full p-1.5 shadow-lg border border-white/50 flex justify-between items-center gap-2 transition-all duration-300">
            
            <!-- Left Side: City Dropdown -->
            <div class="relative shrink-0">
                <button type="button" id="city-btn" onclick="toggleCityMenu()" class="flex items-center gap-2 bg-white/90 border border-gray-200/50 px-4 py-2.5 rounded-full text-sm font-bold text-brand-dark shadow-sm hover:border-brand-orange transition-all duration-300 cursor-pointer">
                    <i class="fa-solid fa-city text-brand-orange"></i>
                    <span id="current-city" class="hidden sm:inline">София</span>
                    <span id="current-city-short" class="sm:hidden">СФ</span>
                    <i class="fa-solid fa-chevron-down text-[10px] text-gray-400"></i>
                </button>
                <div id="city-menu" class="absolute left-0 mt-2 w-48 bg-white/95 backdrop-blur-md rounded-2xl shadow-xl border border-gray-100 hidden transition-all duration-200 overflow-y-auto max-h-60 z-50 custom-scrollbar">
                    <ul class="py-2 text-sm font-semibold text-brand-dark list-none m-0 p-0">
                        <li><button type="button" onclick="setCity('София', 'СФ')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">София</button></li>
                        <li><button type="button" onclick="setCity('Пловдив', 'ПЛ')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Пловдив</button></li>
                        <li><button type="button" onclick="setCity('Варна', 'ВР')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Варна</button></li>
                        <li><button type="button" onclick="setCity('Бургас', 'БГ')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Бургас</button></li>
                        <li><button type="button" onclick="setCity('Русе', 'РС')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Русе</button></li>
                        <li><button type="button" onclick="setCity('Стара Загора', 'СЗ')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Стара Загора</button></li>
                        <li><button type="button" onclick="setCity('Плевен', 'ПН')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Плевен</button></li>
                        <li><button type="button" onclick="setCity('Перник', 'ПК')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Перник</button></li>
                        <li><button type="button" onclick="setCity('Благоевград', 'БЛ')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Благоевград</button></li>
                        <li><button type="button" onclick="setCity('Велико Търново', 'ВТ')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Велико Търново</button></li>
                        <li><button type="button" onclick="setCity('Казанлък', 'КЗ')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Казанлък</button></li>
                        <li><button type="button" onclick="setCity('Габрово', 'ГБ')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Габрово</button></li>
                    </ul>
                </div>
            </div>

            <!-- Middle: Action button leading to Company Cars OR Home -->
            <div class="flex-grow flex justify-center">
                <button type="button" id="nav-action" onclick="handleNavAction()" class="hidden px-5 py-2.5 rounded-full text-sm font-bold transition-all duration-300 flex items-center justify-center gap-2 cursor-pointer bg-white text-brand-orange shadow-sm border border-gray-100/50 hover:text-brand-dark">
                </button>
            </div>

            <!-- Portal user menu -->
            <div class="relative shrink-0">
                <button type="button" id="portal-user-btn" onclick="togglePortalUserMenu()" class="flex items-center gap-2 bg-white/90 border border-gray-200/50 px-3 py-2.5 rounded-full text-sm font-bold text-brand-dark shadow-sm hover:border-brand-orange transition-all duration-300 cursor-pointer" title="Акаунт">
                    <i class="fa-solid fa-user text-brand-orange"></i>
                    <span id="portal-user-name" class="hidden sm:inline max-w-[120px] truncate"></span>
                </button>
                <div id="portal-user-menu" class="absolute right-0 mt-2 w-52 bg-white/95 backdrop-blur-md rounded-2xl shadow-xl border border-gray-100 hidden z-50 overflow-hidden">
                    <ul class="py-2 text-sm font-semibold text-brand-dark list-none m-0 p-0">
                        <li id="portal-menu-admin-choice" class="hidden"><button type="button" onclick="openAdminChoice()" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange">Админ избор</button></li>
                        <li><button type="button" onclick="handleLogout()" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange">Изход</button></li>
                    </ul>
                </div>
            </div>

            <!-- Right Side: Language Dropdown -->
            <div class="relative shrink-0">
                <button type="button" id="lang-btn" onclick="toggleLangMenu()" class="flex items-center gap-2 bg-white/90 border border-gray-200/50 px-4 py-2.5 rounded-full text-sm font-bold text-brand-dark shadow-sm hover:border-brand-orange transition-all duration-300 cursor-pointer">
                    <i class="fa-solid fa-globe text-brand-orange"></i>
                    <span id="current-lang" class="hidden sm:inline">БГ | Български</span>
                    <span id="current-lang-short" class="sm:hidden">БГ</span>
                    <i class="fa-solid fa-chevron-down text-[10px] text-gray-400"></i>
                </button>
                <div id="lang-menu" class="absolute right-0 mt-2 w-44 bg-white/95 backdrop-blur-md rounded-2xl shadow-xl border border-gray-100 hidden transition-all duration-200 overflow-hidden z-50">
                    <ul class="py-2 text-sm font-semibold text-brand-dark list-none m-0 p-0">
                        <li><button type="button" onclick="setLang('bg')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">БГ | Български</button></li>
                        <li><button type="button" onclick="setLang('en')" class="w-full text-left px-4 py-2.5 hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">EN | English</button></li>
                    </ul>
                </div>
            </div>

        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
        
        <div id="page-home" class="global-page space-y-10 sm:space-y-12 block">
            <section class="bg-white border border-gray-200 rounded-[2rem] p-6 sm:p-10 shadow-sm relative overflow-hidden">
                <div class="absolute -right-16 -bottom-16 w-64 h-64 bg-brand-orange opacity-10 rounded-full blur-3xl pointer-events-none"></div>
                <div class="absolute right-8 top-8 hidden lg:block text-brand-orange opacity-10 pointer-events-none"><i class="fa-solid fa-motorcycle text-[160px]"></i></div>
                <div class="relative z-10 max-w-2xl space-y-4">
                    <span data-i18n="hero_badge" class="bg-brand-orange/10 text-brand-orange text-xs sm:text-sm font-extrabold px-3 py-1.5 rounded-md uppercase tracking-wider border border-brand-orange/20 inline-block">АКТУАЛЕН НАРЪЧНИК 2026</span>
                    <h2 data-i18n="hero_title" class="text-3xl sm:text-4xl md:text-5xl font-black text-brand-dark leading-tight">Всичко за твоя успешен старт в Takeaway</h2>
