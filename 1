        function updateUI() {
            const contractVal = document.getElementById("contract")?.value;
            const vehicleVal = document.getElementById("vehicle")?.value;
            const daysVal = document.getElementById("days")?.value;
            const effVal = document.getElementById("eff")?.value;
            if (!contractVal || !vehicleVal || !daysVal || !effVal) {
                document.getElementById("outNet").textContent = "0.00 €";
                document.getElementById("outGross").textContent = "0.00 €";
                document.getElementById("outOrders").textContent = "0";
                document.getElementById("outMonthlyHours").textContent = "0";
                return;
            }
            const contract = Number(contractVal);
            const workedDays = Math.max(0, Number(daysVal));
            const eff = Number(effVal);
            const hours = contract * workedDays;
            const orders = Math.round(eff * hours);
            const isCar = vehicleVal === "personal_car" || vehicleVal === "company_car";
            const kmPerOrder = isCar ? incomeMatrix.kmPerOrder.car : incomeMatrix.kmPerOrder.bike;
            const km = orders * kmPerOrder;
            const baseGross = incomeMatrix.baseSalary[contract];
            let bonusGross = 0;
            const th = incomeMatrix.bonusThresholds[contract];
            const rates = incomeMatrix.bonusRates;
            const n = [
                Math.min(orders, th[0]),
                Math.max(0, Math.min(orders, th[1]) - th[0]),
                Math.max(0, Math.min(orders, th[2]) - th[1]),
                Math.max(0, orders - th[2])
            ];
            bonusGross = (n[0] * rates.base) + (n[1] * rates.mid) + (n[2] * rates.high) + (n[3] * rates.super);
            const amortRate = vehicleVal === "company_car" ? 0 : (vehicleVal.includes("bike") ? incomeMatrix.amortPerKm.bike : incomeMatrix.amortPerKm.car);
            const amortGross = vehicleVal === "company_car" ? 0 : (km * amortRate);
            const totalGross = baseGross + bonusGross + amortGross;
            const totalNet = totalGross - (totalGross * incomeMatrix.tax);
            document.getElementById("outNet").textContent = totalNet.toFixed(2) + " €";
            document.getElementById("outGross").textContent = totalGross.toFixed(2) + " €";
            document.getElementById("outOrders").textContent = orders;
            document.getElementById("outMonthlyHours").textContent = hours;
        }

        // --- УМЕН ПОМОЩНИК ТЪРСЕНЕ ---
        function renderHelperQuickLinks() {
            const container = document.getElementById('quickLinksContainer'); container.innerHTML = '';
            helperQuickLinks[currentLangCode].forEach(link => {
                const btn = document.createElement('button'); btn.className = "px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl text-sm font-semibold text-brand-slate hover:border-brand-orange hover:text-brand-orange hover:shadow-md transition-all cursor-pointer"; btn.innerText = link.l;
                btn.onclick = () => { document.getElementById('searchInput').value = link.t; document.getElementById('searchInput').dispatchEvent(new Event('input')); };
                container.appendChild(btn);
            });
        }
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const query = e.target.value.toLowerCase().trim();
            if (query.length > 0) { document.getElementById('clearBtn').classList.remove('hidden'); document.getElementById('quickCategories').classList.add('hidden'); performHelperSearch(query); }
            else { document.getElementById('clearBtn').classList.add('hidden'); document.getElementById('quickCategories').classList.remove('hidden'); document.getElementById('resultsArea').classList.add('hidden'); }
        });
        document.getElementById('clearBtn').addEventListener('click', function() { document.getElementById('searchInput').value = ''; this.classList.add('hidden'); document.getElementById('quickCategories').classList.remove('hidden'); document.getElementById('resultsArea').classList.add('hidden'); });
        function performHelperSearch(query) {
            const resultsArea = document.getElementById('resultsArea'); const t = translations[currentLangCode]; const queryWords = query.split(/[\s,!?]+/).filter(w => w.length >= 3);
            const results = helperContactData[currentLangCode].filter(item => {
                if (item.title.toLowerCase().includes(query) || item.keywords.some(kw => kw.toLowerCase().includes(query) || query.includes(kw.toLowerCase()))) return true;
                for (let word of queryWords) {
                    let root = word.replace(/(та|те|то|и|а|ът|ят|ния|ният)$/i, ''); if (root.length < 3) root = word;
                    if (item.keywords.some(kw => kw.toLowerCase().includes(root))) return true;
                }
                return false;
            });
            resultsArea.innerHTML = ''; resultsArea.classList.remove('hidden');
            if (results.length === 0) { resultsArea.innerHTML = `<div class="text-center py-8 bg-gray-50 rounded-2xl border border-gray-200 shadow-inner"><i class="fa-solid fa-face-frown-open text-3xl text-gray-400 mb-3"></i><p class="text-brand-slate font-medium">${t.helper_notfound} "${query}".</p></div>`; return; }
            results.forEach(item => {
                const pathHtml = item.path.map((step, i) => `<span class="${i === item.path.length-1 ? 'bg-brand-orange text-white':'bg-white text-brand-dark'} px-2.5 py-1.5 rounded-lg text-[11px] sm:text-xs font-bold shadow-sm border border-gray-200">${step}</span>`).join('<i class="fa-solid fa-chevron-right text-[10px] text-gray-400 mx-2"></i>');
                resultsArea.innerHTML += `<div class="result-card ${item.bg} border ${item.border} rounded-2xl p-5 shadow-sm"><div class="flex items-start gap-4"><div class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0 border text-xl ${item.color} shadow-sm"><i class="fa-solid ${item.icon}"></i></div><div class="space-y-3 w-full"><h3 class="text-base font-extrabold text-brand-dark">${item.title}</h3><div class="bg-white/60 p-3 rounded-xl border"><div class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-2">${t.helper_path}</div><div class="flex flex-wrap items-center gap-y-2">${pathHtml}</div></div><div class="text-xs text-brand-slate flex gap-2 items-start"><i class="fa-solid fa-circle-info mt-0.5 text-brand-orange"></i><span>${item.instructions}</span></div></div></div></div>`;
            });
        }

        // --- ПОКАЗВАНЕ / СКРИВАНЕ НА ПРОТОКОЛА ---
        function toggleProtocolImage() {
            const container = document.getElementById('protocol-image-container');
            const btn = document.getElementById('btn-toggle-protocol');
            const lang = currentLangCode;
            
            if (container.classList.contains('hidden')) {
                container.classList.remove('hidden');
                btn.innerHTML = `<i class="fa-solid fa-eye-slash"></i> <span>${lang === 'en' ? 'Hide sample' : 'Скрий примера'}</span>`;
                btn.classList.replace('bg-blue-600', 'bg-gray-600');
                btn.classList.replace('hover:bg-blue-700', 'hover:bg-gray-700');
            } else {
                container.classList.add('hidden');
                btn.innerHTML = `<i class="fa-solid fa-eye"></i> <span>${lang === 'en' ? 'View sample' : 'Виж примерния протокол'}</span>`;
                btn.classList.replace('bg-gray-600', 'bg-blue-600');
                btn.classList.replace('hover:bg-gray-700', 'hover:bg-blue-700');
            }
        }

        var map, carMap; var mapLayers = [], carMapLayers = [];
        const MAP_ZONES = { sofia: { center: [42.680, 23.325], zoom: 12.4, circles: [{ coords: [42.6975, 23.3320], color: '#2563eb', fillColor: '#3b82f6', fillOpacity: 0.22, weight: 3.5, radius: 2100, label: '1 — Зона Център', labelEn: '1 — Zone Center', pinColor: '#2563eb' }, { coords: [42.6705, 23.3195], color: '#7c3aed', fillColor: '#a855f7', fillOpacity: 0.22, weight: 3.5, radius: 1800, label: '2 — Зона Лозенец', labelEn: '2 — Zone Lozenets', pinColor: '#7c3aed' }, { coords: [42.6730, 23.2925], color: '#16a34a', fillColor: '#22c55e', fillOpacity: 0.22, weight: 3.5, radius: 1950, label: '3 — Зона Борово', labelEn: '3 — Zone Borovo', pinColor: '#16a34a' }, { coords: [42.6560, 23.3610], color: '#dc2626', fillColor: '#ef4444', fillOpacity: 0.22, weight: 3.5, radius: 3850, label: '4 — Зона Дървеница', labelEn: '4 — Zone Darvenitsa', pinColor: '#dc2626' }] } };
        const CAR_MAP_LOCATIONS = { center: [42.70607, 23.30569], zoom: 13, parking: [42.715471, 23.279151], zoneCenter: [42.6975, 23.3320], radius: 2100 };

        function initMaps() {
            if (typeof L === 'undefined') return;
            if (document.getElementById('main-map')) {
                map = L.map('main-map', { zoomControl: true, scrollWheelZoom: false }).setView(MAP_ZONES.sofia.center, MAP_ZONES.sofia.zoom);
                L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', { attribution: '© OpenStreetMap', maxZoom: 19 }).addTo(map);
            }
            if (document.getElementById('company-map')) {
                carMap = L.map('company-map', { zoomControl: false, scrollWheelZoom: false }).setView(CAR_MAP_LOCATIONS.center, CAR_MAP_LOCATIONS.zoom);
                L.control.zoom({ position: 'bottomright' }).addTo(carMap);
                L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', { attribution: '© OpenStreetMap', maxZoom: 19 }).addTo(carMap);
            }
        }

        function showSofiaOnMap() {
            if (!map) return; mapLayers.forEach(layer => map.removeLayer(layer)); mapLayers = []; const t = translations[currentLangCode];
            MAP_ZONES.sofia.circles.forEach((c, index) => {
                const lbl = currentLangCode === 'en' ? c.labelEn : c.label;
                const circle = L.circle(c.coords, { color: c.color, fillColor: c.fillColor, fillOpacity: c.fillOpacity, weight: c.weight, radius: c.radius }).addTo(map).bindPopup(`<strong>${lbl} ${t.map_popup_title}</strong><br><span style="font-size:11px;">${t.map_popup_desc1}</span>`); mapLayers.push(circle);
                const marker = L.marker(c.coords, { icon: L.divIcon({ className: 'custom-div-icon', html: `<div class="flex items-center justify-center w-8 h-8 rounded-full shadow-lg border-2 border-white text-white font-black text-sm" style="background-color: ${c.pinColor};">${index + 1}</div>`, iconSize: [32, 32], iconAnchor: [16, 16] }) }).addTo(map).bindPopup(`<strong>${lbl} ${t.map_popup_title}</strong><br><span style="font-size:11px;">${t.map_popup_desc2}</span>`); mapLayers.push(marker);
            });
        }

        function showCompanyLocationsOnMap() {
            if (!carMap) return; carMapLayers.forEach(layer => carMap.removeLayer(layer)); carMapLayers = []; const t = translations[currentLangCode];
            const zoneCircle = L.circle(CAR_MAP_LOCATIONS.zoneCenter, { color: '#2563eb', fillColor: '#3b82f6', fillOpacity: 0.22, weight: 3.5, radius: CAR_MAP_LOCATIONS.radius }).addTo(carMap).bindPopup(`<strong>1 — ${t.car_loc_zone_title}</strong>`); carMapLayers.push(zoneCircle);
            const zoneMarker = L.marker(CAR_MAP_LOCATIONS.zoneCenter, { icon: L.divIcon({ className: 'custom-div-icon', html: `<div class="flex items-center justify-center w-8 h-8 rounded-full shadow-lg border-2 border-white text-white font-black text-sm" style="background-color: #2563eb;">1</div>`, iconSize: [32, 32], iconAnchor: [16, 16] }) }).addTo(carMap).bindPopup(`<strong>1 — ${t.car_loc_zone_title}</strong>`); carMapLayers.push(zoneMarker);
            const parkingMarker = L.marker(CAR_MAP_LOCATIONS.parking, { icon: L.divIcon({ className: 'custom-div-icon', html: `<div class="pulse-marker flex items-center justify-center w-10 h-10 rounded-full shadow-xl border-2 border-white text-white text-lg bg-brand-orange"><i class="fa-solid fa-car"></i></div>`, iconSize: [40, 40], iconAnchor: [20, 20] }) }).addTo(carMap).bindPopup(`<strong>${t.car_loc_parking_title}</strong>`); carMapLayers.push(parkingMarker);
        }

        window.onload = function() {
            initMaps();
            bootstrapApp().then(() => {
                if (currentProfile && document.getElementById('screen-portal') && !document.getElementById('screen-portal').classList.contains('hidden')) {
                    setLang('bg');
                    setCity('София', 'СФ');
                    switchGlobalPage('home');
                    openCarTab('car-map');
                }
            });
        }
    </script>
</body>
