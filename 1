                let val = el.value;
                if (path.startsWith('bonusThresholds.')) {
                    const hours = Number(path.split('.')[1]);
                    incomeMatrix.bonusThresholds[hours] = val.split(',').map((x) => Number(x.trim())).filter((x) => !Number.isNaN(x));
                    return;
                }
                if (typeOfMatrixPath(path) === 'number') val = val === '' ? 0 : Number(val);
                setMatrixValueByPath(path, val);
            });
            syncIncomeMatrixTextsToTranslations();
            await savePortalContent();
            renderIncomeMatrixSection();
            const status = document.getElementById('matrix-save-status');
            if (status) {
                status.textContent = 'Раздел „4. Доходи и Бонусна схема“ е запазен. Промените са видими в потребителския портал.';
                status.classList.remove('hidden');
                setTimeout(() => status.classList.add('hidden'), 4000);
            }
            if (!document.getElementById('screen-portal').classList.contains('hidden')) {
                setLang(currentLangCode || 'bg');
            }
        }

        function deepMerge(target, source) {
            const out = Array.isArray(target) ? [...target] : { ...target };
            if (!source || typeof source !== 'object') return out;
            Object.keys(source).forEach((key) => {
                if (source[key] && typeof source[key] === 'object' && !Array.isArray(source[key])) {
                    out[key] = deepMerge(out[key] || {}, source[key]);
                } else {
                    out[key] = source[key];
                }
            });
            return out;
        }

