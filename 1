        }

        function typeOfMatrixPath(path) {
            if (path === 'tax') return 'number';
            if (path.startsWith('baseSalary.')) return 'number';
            if (path.startsWith('bonusRates.')) return 'number';
            if (path.startsWith('kmPerOrder.') || path.startsWith('amortPerKm.')) return 'number';
            return 'text';
        }

        function setMatrixValueByPath(path, value) {
            const parts = path.split('.');
            let ref = incomeMatrix;
            for (let i = 0; i < parts.length - 1; i += 1) {
                const key = /^\d+$/.test(parts[i]) ? Number(parts[i]) : parts[i];
                if (ref[key] === undefined) {
                    ref[key] = /^\d+$/.test(parts[i + 1]) ? {} : {};
                }
                ref = ref[key];
            }
            const last = parts[parts.length - 1];
            const lastKey = /^\d+$/.test(last) ? Number(last) : last;
            ref[lastKey] = value;
        }

        function getMatrixValueByPath(path) {
            return path.split('.').reduce((acc, key) => (acc == null ? undefined : acc[key]), incomeMatrix);
        }

