            errEl.classList.add('hidden');
            try {
                if (usingLocalAuth) {
                    const users = getLocalUsers();
                    const found = Object.values(users).find((u) => u.username === username && u.password === password && u.is_active);
                    if (!found) throw new Error('Грешно потребителско име или парола.');
                    currentProfile = { ...found, id: found.username };
                    localStorage.setItem('takeaway-portal-session', found.username);
                    afterLogin();
